{
  "name": "cleaning-services-enterprise-2026",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && nodemon src/server.ts",
    "dev:frontend": "cd frontend && next dev -p 3000",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && tsc && prisma generate",
    "build:frontend": "cd frontend && next build",
    "start": "NODE_ENV=production node backend/dist/server.js",
    "db:generate": "cd backend && prisma generate",
    "db:migrate": "cd backend && prisma migrate dev",
    "db:push": "cd backend && prisma db push",
    "db:seed": "cd backend && ts-node prisma/seed.ts",
    "db:studio": "cd backend && prisma studio",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest"
  },
  "workspaces": ["backend", "frontend"],
  "engines": { "node": ">=18.0.0" }
}
